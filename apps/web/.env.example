# =============================================================
# KalaTask Web — Environment Variables Template
# =============================================================
# Copy file ini ke .env.local lalu isi dengan credential dari owner.
# JANGAN commit .env.local — sudah di-ignore di .gitignore root.
# =============================================================

# Supabase project URL (https://<project-ref>.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url

# Supabase anon (public) key — aman ke-expose di client karena
# RLS policy di DB jadi security boundary (lihat ADR-002).
# JANGAN pakai service_role key di sini — itu server-only.
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
