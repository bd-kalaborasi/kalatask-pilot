# =============================================================
# Supabase CLI — Local Environment Variables Template
# =============================================================
# Copy file ini ke supabase/.env (sudah di-gitignore di root .gitignore).
# Pakai untuk authenticate Supabase CLI saat link/push/pull terhadap
# remote project iymtuvslcsoitgoulmmk.
#
# Note: SUPABASE_ACCESS_TOKEN bersifat PERSONAL — setiap developer
# punya token sendiri dari https://supabase.com/dashboard/account/tokens.
# JANGAN share token via Slack/email/dll.
# =============================================================

# Personal access token untuk supabase login + supabase link.
# Generate di: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_personal_access_token

# DB password untuk supabase db push terhadap remote.
# Dapatkan dari Supabase dashboard → Project Settings → Database.
SUPABASE_DB_PASSWORD=your_db_password
